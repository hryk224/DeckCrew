# === Google API ===
# A single Google API key powers both music generation (Lyria) and
# DJ agent LLM (Gemini). Omit to run in mock mode (no API calls).
GOOGLE_API_KEY=

# === Music Generation ===
MUSIC_BACKEND=mock                          # mock | lyria
LYRIA_MODEL=models/lyria-realtime-exp       # Music generation model

# === Agent LLM (advanced override) ===
# By default, GOOGLE_API_KEY is used with Gemini. Set these to use
# a different LLM provider (OpenAI, Ollama, etc.) instead.
# LLM_API_KEY=                              # Override API key
# LLM_BASE_URL=                             # Override base URL
# LLM_MODEL_NAME=                           # Override model name

# === Server ===
BACKEND_PORT=8000                           # Backend server port
CORS_ORIGINS=http://localhost:3000,http://localhost:3001  # Comma-separated allowed origins (must override for non-local deployment)

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000    # Backend API base URL
