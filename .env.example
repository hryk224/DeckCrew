# === Music Generation (Lyria / Google) ===
MUSIC_BACKEND=mock                          # mock | lyria
GOOGLE_API_KEY=                             # Google API key for Lyria Realtime
LYRIA_MODEL=models/lyria-realtime-exp       # Music generation model

# === Agent LLM (OpenAI-compatible API) ===
# Omit these to keep agents on mock (no LLM calls).
# Supports OpenAI, Gemini (via compat endpoint), Ollama, etc.
LLM_API_KEY=                                # API key for LLM provider
LLM_BASE_URL=                               # Base URL (omit for OpenAI default)
LLM_MODEL_NAME=                             # Model name (e.g. gpt-4o-mini, gemini-2.5-flash)

# === Server ===
BACKEND_PORT=8000                           # Backend server port
CORS_ORIGINS=http://localhost:3000,http://localhost:3001  # Comma-separated allowed origins (must override for non-local deployment)

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000    # Backend API base URL
