# === Backend ===
MUSIC_BACKEND=mock          # mock | lyria
GOOGLE_API_KEY=             # Google API key (Lyria, Gemini LLM). LYRIA_API_KEY also accepted for backward compat.
LLM_MODEL=                  # LLM model identifier for agent calls
BACKEND_PORT=8000           # Backend server port

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000  # Backend API base URL
